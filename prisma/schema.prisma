// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String // hashed bcrypt password
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String         @id @default(uuid())
  name        String
  slug        String         @unique
  description String
  price       Int // price in IDR (Rupiah)
  stock       Int
  imageUrl    String? // main image URL
  sizes       ProductSize[]
  images      ProductImage[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  orderItems  OrderItem[]
}

model ProductSize {
  id        String  @id @default(uuid())
  size      String // e.g., "30ml", "50ml", "100ml"
  priceAdd  Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String // image path/URL
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id // Custom order receipt number, e.g., ORD-YYYYMMDD-XXXX
  customerName    String
  customerPhone   String
  customerAddress String
  customerNotes   String?
  paymentMethod   String // "BCA", "MANDIRI", or "QRIS"
  totalAmount     Int // total amount including unique code if any
  status          String      @default("PENDING") // "PENDING", "VERIFIED", "COMPLETED", "CANCELLED"
  receiptImg      String? // URL of uploaded payment receipt
  shippingResi    String? // Shipping tracking number
  codLocation     String? // Meeting location and details for COD
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String // snapshot of product name at purchase
  size        String // snapshot of size at purchase
  price       Int // snapshot of price at purchase
  quantity    Int
}
